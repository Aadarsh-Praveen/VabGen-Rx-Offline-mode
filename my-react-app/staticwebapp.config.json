{
  "routes": [
    {
      "route": "/api/*",
      "statusCode": 404
    },
    {
      "route": "/*",
      "serve": "/index.html",
      "statusCode": 200
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/*.js", "/*.css", "/*.png", "/*.jpg", "/*.ico", "/*.svg"]
  }
}